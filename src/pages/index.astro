---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/home.css';
---

<BaseLayout
  title="Catalise.me: Sistemas e agentes de IA co-operando o seu negócio."
  description="A Catalise.me conecta todos os seus setores numa só inteligência que atende, vende e opera processos 24 horas por dia. Em 10 a 12 semanas."
  ogTitle="Catalise.me: Sistemas e agentes de IA co-operando o seu negócio."
  ogDescription="Mais velocidade, menos custos, mais resultados. Sistema operacional com IA em 10-12 semanas."
  ogUrl="https://catalise.me/"
  canonical="https://catalise.me/"
  keywords="inteligência artificial para empresas, agentes de IA, automação de processos, Opera OS, Catalise.me"
  pageType="home"
>

    <!-- ══════════════ HERO — EDITORIAL FULLSCREEN ══════════════ -->
    <section class="hero-editorial" aria-labelledby="hero-heading" id="hero">

      <!-- BG Layer: vídeo + dark overlay -->
      <div class="hero-bg-layer" aria-hidden="true" data-media-frame>
        <video class="hero-video-bg" id="hero-bg-video" data-src="/assets/background-looping-video.mp4" loop muted playsinline preload="none"></video>
        <div class="hero-bg-overlay"></div>
        <div class="hero-bg-grain"></div>
      </div>

      <!-- Grid decoration: cruzes + nos pontos do grid -->
      <div class="hero-grid-crosses" aria-hidden="true">
        <span class="hx" style="--hx: 3.5%; --hy: 9%"></span>
        <span class="hx" style="--hx: 34%; --hy: 9%"></span>
        <span class="hx" style="--hx: 65%; --hy: 9%"></span>
        <span class="hx" style="--hx: 96%; --hy: 9%"></span>
        <span class="hx" style="--hx: 3.5%; --hy: 37%"></span>
        <span class="hx" style="--hx: 34%; --hy: 37%"></span>
        <span class="hx" style="--hx: 65%; --hy: 37%"></span>
        <span class="hx" style="--hx: 96%; --hy: 37%"></span>
        <span class="hx" style="--hx: 3.5%; --hy: 64%"></span>
        <span class="hx" style="--hx: 96%; --hy: 64%"></span>
        <span class="hx" style="--hx: 3.5%; --hy: 92%"></span>
        <span class="hx" style="--hx: 34%; --hy: 92%"></span>
        <span class="hx" style="--hx: 65%; --hy: 92%"></span>
        <span class="hx" style="--hx: 96%; --hy: 92%"></span>
      </div>

      <!-- Content Layer -->
      <div class="hero-content-layer">

        <!-- Top row: headline + badge -->
        <div class="hero-top-row">
          <div class="hero-headline-block">
            <h1 id="hero-heading" class="hero-editorial-heading hero-animate-1">
              Sistemas e agentes de IA<br>
              <span>co-operando o seu negócio.</span>
            </h1>
          </div>
        </div>

        <!-- Eyebrow: dot + subtitle -->
        <div class="hero-eyebrow-editorial hero-animate-3">
          <span class="hero-eyebrow-dot" aria-hidden="true"></span>
          <span>Enquanto você cuida do que só você pode fazer, instalamos a inteligência que mantém atendimento, vendas e operação funcionando sem depender de você.</span>
        </div>

        <!-- CTAs -->
        <div class="hero-ctas-editorial hero-animate-4">
          <a href="/contato" class="btn btn-primary-editorial btn-lg" id="hero-cta-primary">
            Diagnóstico gratuito <span class="btn-arrow">→</span>
          </a>
          <a href="/opera-os" class="btn-secondary-editorial" id="hero-cta-secondary">
            Conhecer o método OPERA
          </a>
        </div>

      </div>


    </section>

    <!-- ══════════════ TICKER DE MÉTRICAS ══════════════ -->
    <div class="metrics-ticker" aria-hidden="true">
      <div class="ticker-track">
        <div class="ticker-item">
          <strong>286h</strong><span class="ticker-sep"></span><span>por ano recuperadas por empresa</span>
        </div>
        <div class="ticker-item">
          <strong>80%</strong><span class="ticker-sep"></span><span>queda na conversão após 15min sem resposta</span>
        </div>
        <div class="ticker-item">
          <strong>10–12 semanas</strong><span class="ticker-sep"></span><span>para sistema completo rodando</span>
        </div>
        <div class="ticker-item">
          <strong>24/7</strong><span class="ticker-sep"></span><span>agentes de IA co-operando enquanto você dorme</span>
        </div>
        <div class="ticker-item">
          <strong>60–90 dias</strong><span class="ticker-sep"></span><span>retorno médio do investimento</span>
        </div>
        <div class="ticker-item">
          <strong>67%</strong><span class="ticker-sep"></span><span>dos gestores decidem sem dado atualizado</span>
        </div>
        <div class="ticker-item">
          <strong>51%</strong><span class="ticker-sep"></span><span>do tempo de operação em tarefas coordenáveis</span>
        </div>
        <!-- Duplicate for loop -->
        <div class="ticker-item" aria-hidden="true">
          <strong>286h</strong><span class="ticker-sep"></span><span>por ano recuperadas por empresa</span>
        </div>
        <div class="ticker-item" aria-hidden="true">
          <strong>80%</strong><span class="ticker-sep"></span><span>queda na conversão após 15min sem resposta</span>
        </div>
        <div class="ticker-item" aria-hidden="true">
          <strong>10–12 semanas</strong><span class="ticker-sep"></span><span>para sistema completo rodando</span>
        </div>
        <div class="ticker-item" aria-hidden="true">
          <strong>24/7</strong><span class="ticker-sep"></span><span>agentes de IA co-operando enquanto você dorme</span>
        </div>
        <div class="ticker-item" aria-hidden="true">
          <strong>60–90 dias</strong><span class="ticker-sep"></span><span>retorno médio do investimento</span>
        </div>
        <div class="ticker-item" aria-hidden="true">
          <strong>67%</strong><span class="ticker-sep"></span><span>dos gestores decidem sem dado atualizado</span>
        </div>
        <div class="ticker-item" aria-hidden="true">
          <strong>51%</strong><span class="ticker-sep"></span><span>do tempo de operação em tarefas coordenáveis</span>
        </div>
      </div>
    </div>

    <!-- ══════════════ LOGO STRIP — Segmentos ══════════════ -->
    <div class="logo-strip" aria-hidden="true">
      <div class="logo-strip-track">
        <span class="logo-strip-item">Hotelaria</span>
        <span class="logo-strip-dot"></span>
        <span class="logo-strip-item">Clínicas &amp; Saúde</span>
        <span class="logo-strip-dot"></span>
        <span class="logo-strip-item">Universidades/Faculdades</span>
        <span class="logo-strip-dot"></span>
        <span class="logo-strip-item">Imobiliárias</span>
        <span class="logo-strip-dot"></span>
        <span class="logo-strip-item">Escritórios Jurídicos</span>
        <span class="logo-strip-dot"></span>
        <span class="logo-strip-item">Educação</span>
        <span class="logo-strip-dot"></span>
        <span class="logo-strip-item">Serviços B2B</span>
        <span class="logo-strip-dot"></span>
        <span class="logo-strip-item">Concessionárias</span>
        <span class="logo-strip-dot"></span>
        <!-- duplicate -->
        <span class="logo-strip-item">Hotelaria</span>
        <span class="logo-strip-dot"></span>
        <span class="logo-strip-item">Clínicas &amp; Saúde</span>
        <span class="logo-strip-dot"></span>
        <span class="logo-strip-item">Universidades/Faculdades</span>
        <span class="logo-strip-dot"></span>
        <span class="logo-strip-item">Imobiliárias</span>
        <span class="logo-strip-dot"></span>
        <span class="logo-strip-item">Escritórios Jurídicos</span>
        <span class="logo-strip-dot"></span>
        <span class="logo-strip-item">Educação</span>
        <span class="logo-strip-dot"></span>
        <span class="logo-strip-item">Serviços B2B</span>
        <span class="logo-strip-dot"></span>
        <span class="logo-strip-item">Concessionárias</span>
        <span class="logo-strip-dot"></span>
      </div>
    </div>

    <!-- ══════════════ PROBLEMA (Stats) ══════════════ -->
    <section id="problema" class="dark-section" aria-labelledby="problema-heading">
      <div class="container">
        <div class="section-header reveal">
          <p class="eyebrow">O Problema</p>
          <h2 id="problema-heading">
            O problema não é a sua equipe. É a <em>falta de coordenação entre os setores</em>.
          </h2>
          <p>O time é bom. As ferramentas funcionam. Mas os setores não conversam. Cada área com sua planilha, sua decisão, seu dado isolado.</p>
        </div>

        <div class="stats-arpeggio-container reveal">
          <div class="stats-arpeggio-header">
            <span class="stats-arpeggio-eyebrow">O Custo Oculto da Descoordenação</span>
          </div>
          <div class="stats-arpeggio-grid">
            <div class="stat-item-arpeggio">
              <span class="stat-label-arpeggio">Horas perdidas em<br>sistemas desconectados</span>
              <span class="stat-number-arpeggio" data-target="286" data-suffix="h">286h</span>
            </div>
            <div class="stat-item-arpeggio">
              <span class="stat-label-arpeggio">Tempo de operação<br>em tarefas manuais</span>
              <span class="stat-number-arpeggio" data-target="51" data-suffix="%">51%</span>
            </div>
            <div class="stat-item-arpeggio">
              <span class="stat-label-arpeggio">Decisões tomadas<br>sem dado atualizado</span>
              <span class="stat-number-arpeggio" data-target="67" data-suffix="%">67%</span>
            </div>
            <div class="stat-item-arpeggio">
              <span class="stat-label-arpeggio">Queda de conversão<br>após 15 minutos</span>
              <span class="stat-number-arpeggio" data-target="80" data-suffix="%">80%</span>
            </div>
          </div>
        </div>

        <p class="problema-conclusion reveal">
          É a operação crescendo mais rápido que a inteligência que a coordena.
        </p>
      </div>
    </section>

    <!-- ══════════════ SOLUÇÃO ══════════════ -->
    <section id="solucao" class="solucao-section" aria-labelledby="solucao-heading">
      <div class="solucao-grid-pattern" aria-hidden="true">
        <svg class="solucao-grid-svg">
          <defs>
            <pattern id="grid-pattern-solucao" width="40" height="40" patternUnits="userSpaceOnUse" x="-1" y="-1">
              <path d="M.5 40V.5H40" fill="none" />
            </pattern>
          </defs>
          <rect width="100%" height="100%" stroke-width="0" fill="url(#grid-pattern-solucao)" />
          <svg x="-1" y="-1" class="solucao-grid-squares">
            <rect stroke-width="0" width="39" height="39" x="161" y="41" />
            <rect stroke-width="0" width="39" height="39" x="201" y="41" />
            <rect stroke-width="0" width="39" height="39" x="41" y="241" />
            <rect stroke-width="0" width="39" height="39" x="481" y="161" />
            <rect stroke-width="0" width="39" height="39" x="521" y="161" />
            <rect stroke-width="0" width="39" height="39" x="521" y="201" />
            <rect stroke-width="0" width="39" height="39" x="801" y="81" />
            <rect stroke-width="0" width="39" height="39" x="1121" y="321" />
            <rect stroke-width="0" width="39" height="39" x="1161" y="321" />
            <rect stroke-width="0" width="39" height="39" x="1441" y="121" />
          </svg>
        </svg>
      </div>
      <div class="container solucao-content-wrapper">
        <div class="section-header reveal">
          <p class="eyebrow">A Solução</p>
          <h2 id="solucao-heading">
            Cada camada que <em>conectamos</em>.
          </h2>
          <p>Uma camada de inteligência sobre os sistemas que você já usa. Não trocamos suas ferramentas. Não substituímos sua equipe. Conectamos tudo e colocamos agentes de IA para operar.</p>
          <p style="margin-top: 12px;">Os setores passam a compartilhar dados em tempo real. Os agentes atendem clientes, organizam o funil e executam processos. E o sistema melhora a cada operação. <strong>A gente chama essa camada de Opera.</strong></p>
        </div>

        <div class="solucao-editorial-table reveal">
          
          <div class="solucao-editorial-row">
            <div class="ser-col ser-index">{'{01}'}</div>
            <div class="ser-col ser-category">Marketing</div>
            <div class="ser-col ser-desc">Toma uma decisão e vendas, finanças e operação são notificados automaticamente. Antes da próxima reunião.</div>
            <div class="ser-col ser-tags">
              <span class="ser-tag">Integração CRM</span>
              <span class="ser-tag">Automação de Pipeline</span>
            </div>
          </div>

          <div class="solucao-editorial-row">
            <div class="ser-col ser-index">{'{02}'}</div>
            <div class="ser-col ser-category">Operação</div>
            <div class="ser-col ser-desc">Detecta um gargalo e o sistema reorganiza prioridades de toda a empresa. Sem reunião, sem ata, sem fricção.</div>
            <div class="ser-col ser-tags">
              <span class="ser-tag">Reorganização Dinâmica</span>
              <span class="ser-tag">Sincronia Financeira</span>
            </div>
          </div>

          <div class="solucao-editorial-row">
            <div class="ser-col ser-index">{'{03}'}</div>
            <div class="ser-col ser-category">Atendimento</div>
            <div class="ser-col ser-desc">Recebe uma reclamação e a inteligência inteira aprende com isso. O próximo cliente não passa pelo mesmo problema.</div>
            <div class="ser-col ser-tags">
              <span class="ser-tag">Aprendizado Contínuo</span>
              <span class="ser-tag">Prevenção de Atrito</span>
            </div>
          </div>

        </div>

        <!-- Diagrama camada agêntica -->
        <div class="agentic-diagram reveal" style="transition-delay: 200ms;">
          <p class="agentic-diagram-title">como a camada agêntica conecta sua empresa</p>
          <div class="agentic-system">
            
            <div class="agentic-layer top-layer">
              <div class="agentic-node">Marketing</div>
              <div class="agentic-node">Vendas / CRM</div>
              <div class="agentic-node">Atendimento</div>
            </div>

            <div class="agentic-core-wrapper">
              <div class="agentic-core-glow"></div>
              <div class="agentic-core">
                <span class="core-pulse"></span>
                Opera OS
              </div>
            </div>

            <div class="agentic-layer bottom-layer">
              <div class="agentic-node">Operação</div>
              <div class="agentic-node">Financeiro</div>
              <div class="agentic-node">Dashboard</div>
            </div>
            
          </div>
        </div>

        <p class="solucao-metafora reveal" style="margin-top: var(--space-12);">
          A informação circula entre os setores sem reunião, sem retrabalho, sem depender da memória de ninguém.
        </p>

        <div class="reveal" style="text-align: center; margin-top: 48px;">
          <a href="/opera-os" class="btn btn-secondary">
            Como funciona, na prática <span class="btn-arrow">→</span>
          </a>
        </div>
      </div>
    </section>

    <!-- ══════════════ DIFERENCIAL ══════════════ -->
    <section id="diferencial" aria-labelledby="diferencial-heading">
      <div class="container">
        <div class="section-header reveal">
          <p class="eyebrow">O Diferencial</p>
          <h2 id="diferencial-heading">Trabalhamos para <em>não sermos necessários</em>.</h2>
          <p>A maioria tenta resolver comprando mais uma coisa. Agência, consultoria, software. Cada uma entrega só um pedaço.</p>
        </div>

        <!-- Tabela editorial de comparação -->
        <div class="dif-versus reveal">
          <div class="dif-versus-others">
            <div class="dif-versus-row">
              <span class="dif-versus-label">Agência</span>
              <span class="dif-versus-result">entrega campanha. E vai embora quando o contrato acaba.</span>
            </div>
            <div class="dif-versus-row">
              <span class="dif-versus-label">Consultoria</span>
              <span class="dif-versus-result">entrega relatório. Você implementa sozinho.</span>
            </div>
            <div class="dif-versus-row">
              <span class="dif-versus-label">Software</span>
              <span class="dif-versus-result">entrega login. Mais um sistema desconectado dos outros.</span>
            </div>
          </div>
          <div class="dif-versus-catalise">
            <p class="dif-versus-catalise-desc"><strong>Fazemos o sistema agêntico co-operar com seu negócio:</strong> construído, integrado, equipe treinada e evoluindo no tempo.</p>
          </div>
        </div>

        <!-- Grade numerada de diferenciais -->
        <div class="dif-grid reveal">
          <div class="dif-item">
            <span class="dif-num">01</span>
            <div class="dif-body">
              <h3>Implementação completa, não recomendação.</h3>
              <p>Quando saímos, está funcionando. Não entregamos um plano para você executar.</p>
            </div>
          </div>
          <div class="dif-item">
            <span class="dif-num">02</span>
            <div class="dif-body">
              <h3>Sistema proprietário, não revenda.</h3>
              <p>O Opera e o CRM Matika são nossos. Não dependem de terceiros que mudam a cada atualização.</p>
            </div>
          </div>
          <div class="dif-item">
            <span class="dif-num">03</span>
            <div class="dif-body">
              <h3>Memória permanente e auto-melhoria.</h3>
              <p>O sistema registra cada decisão e fica mais inteligente a cada semana. Não é uma automação congelada.</p>
            </div>
          </div>
          <div class="dif-item">
            <span class="dif-num">04</span>
            <div class="dif-body">
              <h3>Método e evolução contínua.</h3>
              <p>Cinco fases para implantar e acompanhamento depois. O sistema cresce junto com o negócio.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════ MÉTODO OPERA (Arpeggio Sticky Scroll) ══════════════ -->
    <section id="opera" class="method-stack-section" aria-labelledby="opera-heading">
      
      <!-- Introduction Header -->
      <div class="container">
        <div class="section-header reveal" style="margin-bottom: var(--space-8); padding-top: var(--space-12);">
          <p class="eyebrow">O Método</p>
          <h2 id="opera-heading">Um método. Cinco movimentos. <em>Uma transformação.</em></h2>
          <p>A ordem importa tanto quanto o que fazemos. Começar pela ferramenta errada, na hora errada, é a razão pela qual a maioria das implementações de IA falha silenciosamente.</p>
          <p>O OPERA foi desenhado para respeitar o ritmo da transformação real. Primeiro entender, depois planejar, depois arquitetar, depois construir, depois afinar. Nunca ao contrário.</p>
          <p>Você sabe o que acontece em cada semana. Sabe o que recebe no fim de cada fase. E sabe exatamente como o negócio estará funcionando nas semanas 10 a 12.</p>
        </div>
      </div>

      <!-- The Full-Bleed Sticky Stack -->
      <div class="method-stack" aria-label="Método OPERA: cinco fases em sequência">
        
        <!-- Phase O -->
        <div class="method-sticky-section" data-media-frame>
          <video data-src="/assets/organizacao.mp4" poster="/assets/organizacao.png" class="method-bg-image" loop muted playsinline preload="none" aria-hidden="true"></video>
          <div class="method-overlay"></div>
          <div class="method-content">
            <div class="method-chips">
              <span class="method-chip">Fase 1</span>
              <span class="method-chip">Semanas 1–2</span>
            </div>
            <h3 class="method-headline">Organização</h3>
             <p class="method-desc">Mapeamos cada processo, do primeiro contato ao pós-venda, e classificamos os gargalos por impacto financeiro. <strong>Entrega: relatório de gargalos priorizados.</strong></p>
          </div>
        </div>

        <!-- Phase P -->
        <div class="method-sticky-section" data-media-frame>
          <video data-src="/assets/planejamento.mp4" poster="/assets/planejamento.png" class="method-bg-image" loop muted playsinline preload="none" aria-hidden="true"></video>
          <div class="method-overlay"></div>
          <div class="method-content">
            <div class="method-chips">
              <span class="method-chip">Fase 2</span>
              <span class="method-chip">Semanas 2–3</span>
            </div>
            <h3 class="method-headline">Planejamento</h3>
             <p class="method-desc">Definimos o escopo, a ordem de implantação e o ROI projetado por iniciativa. <strong>Entrega: plano mestre com metas e investimento fechado.</strong></p>
          </div>
        </div>

        <!-- Phase E -->
        <div class="method-sticky-section" data-media-frame>
          <video data-src="/assets/estrategia.mp4" poster="/assets/estrategia.png" class="method-bg-image" loop muted playsinline preload="none" aria-hidden="true"></video>
          <div class="method-overlay"></div>
          <div class="method-content">
            <div class="method-chips">
              <span class="method-chip">Fase 3</span>
              <span class="method-chip">Semanas 3–4</span>
            </div>
            <h3 class="method-headline">Estratégia</h3>
             <p class="method-desc">Desenhamos a arquitetura: quais agentes, quais integrações, como tudo se conecta e o plano de adoção da equipe. <strong>Entrega: blueprint técnico completo.</strong></p>
          </div>
        </div>

        <!-- Phase R -->
        <div class="method-sticky-section" data-media-frame>
          <video data-src="/assets/realizacao.mp4" poster="/assets/realizacao.png" class="method-bg-image" loop muted playsinline preload="none" aria-hidden="true"></video>
          <div class="method-overlay"></div>
          <div class="method-content">
            <div class="method-chips">
              <span class="method-chip">Fase 4</span>
              <span class="method-chip">Semanas 4–8</span>
            </div>
            <h3 class="method-headline">Realização</h3>
             <p class="method-desc">Construímos, integramos e ativamos. Os agentes entram em operação e a equipe é treinada. <strong>Entrega: sistema funcionando e documentado.</strong></p>
          </div>
        </div>

        <!-- Phase A -->
        <div class="method-sticky-section" data-media-frame>
          <video data-src="/assets/afinacao.mp4" poster="/assets/afinamento.png" class="method-bg-image" loop muted playsinline preload="none" aria-hidden="true"></video>
          <div class="method-overlay"></div>
          <div class="method-content">
            <div class="method-chips">
              <span class="method-chip">Fase 5</span>
              <span class="method-chip">Semanas 8–10</span>
            </div>
            <h3 class="method-headline">Afinação</h3>
             <p class="method-desc">Ajustamos os agentes com base em operação real dos primeiros 30 dias. <strong>Entrega: sistema calibrado para o seu negócio e certificado.</strong></p>
          </div>
        </div>

      </div>
    </section>

    <!-- ══════════════ ANTES / DEPOIS ══════════════ -->
    <section id="resultados" aria-labelledby="resultados-heading">
      <div class="container">
        <div class="section-header reveal">
          <p class="eyebrow">O Que Muda</p>
          <h2 id="resultados-heading">O que muda em <em>90 dias</em>.</h2>
        </div>

        <div class="before-after reveal">
