---
import { locales, localizedHref, navigation, type Locale } from '../i18n/config';
interface Props {
  currentPath?: string;
  locale?: Locale;
  localizedPaths?: Partial<Record<Locale, string>>;
}

const { currentPath = '/', locale = 'pt', localizedPaths } = Astro.props;

const links = [
  { href: '/', label: navigation[locale].home },
  { href: '/sobre', label: navigation[locale].about },
  { href: '/opera-os', label: navigation[locale].opera },
  { href: '/contato', label: navigation[locale].contact },
];

const currentBasePath = locale === 'pt' ? currentPath : currentPath.replace(new RegExp(`^/${locale}(?=/|$)`), '') || '/';

function isActive(linkHref: string): boolean {
  if (linkHref === '/') return currentBasePath === '/' || currentBasePath === '/index.html';
  return currentBasePath === linkHref || currentBasePath.startsWith(`${linkHref}/`);
}

const needsWhiteLogo = currentPath.includes('/contato') || currentPath.includes('/sobre');
---

<!-- NAV -->
<nav class="nav" aria-label="Navegação principal">
  <div class="nav-inner">
    <a href={localizedHref('/', locale)} class="nav-logo" aria-label="Catalise.me">
      <img src="/assets/logo-catalise-me.svg" alt="Catalise.me" class={`nav-logo-img ${needsWhiteLogo ? 'invert-logo' : ''}`} width="420" height="84">
    </a>

    <ul class="nav-links" role="list">
      {links.map(link => (
        <li><a href={localizedHref(link.href, locale)} class={isActive(link.href) ? 'active' : ''} aria-current={isActive(link.href) ? 'page' : undefined}>{link.label}</a></li>
      ))}
    </ul>

    {localizedPaths && (
      <div class="nav-language" aria-label="Language selector">
        {(Object.keys(localizedPaths) as Locale[]).map((language) => (
          <a href={localizedPaths[language]} hreflang={locales[language].code} lang={locales[language].code} aria-current={language === locale ? 'true' : undefined}>{locales[language].label}</a>
        ))}
      </div>
    )}

    <button class="nav-hamburger" aria-label="Abrir menu" aria-expanded="false" aria-controls="mobile-menu" id="hamburger-btn">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<!-- Mobile menu -->
<nav class="nav-mobile" aria-label="Menu mobile" id="mobile-menu">
  {links.map(link => (
    <a href={localizedHref(link.href, locale)} aria-current={isActive(link.href) ? 'page' : undefined}>{link.label}</a>
  ))}
</nav>
