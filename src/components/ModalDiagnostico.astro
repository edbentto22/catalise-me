  },
  en: {
    close: 'Close', title: 'Free', accent: 'Diagnostic Session', name: 'Full name', namePlaceholder: 'Your name', company: 'Company and role', companyPlaceholder: 'Company name', email: 'Email', emailPlaceholder: 'you@example.com', phone: 'Phone / WhatsApp', phonePlaceholder: '+1 000 000 0000', revenue: 'Average monthly revenue', revenuePrompt: 'Select a range', revenueOptions: ['Up to R$ 50k', 'R$ 50k – R$ 150k', 'R$ 150k – R$ 500k', 'R$ 500k – R$ 2m', 'Over R$ 2m'], source: 'How did you hear about us?', sourcePrompt: 'Select an option', referral: 'Referral', other: 'Other', submit: 'REQUEST A FREE DIAGNOSTIC SESSION →', footer: 'No commitment · Response within 24 hours', network: 'We could not complete the submission. Your information is still filled in.', whatsapp: 'Talk on WhatsApp', successTitle: 'Request received', success: 'Your browser sent the information. If you do not hear from us within 24 hours, contact us on WhatsApp.', required: 'This field is required.', minChars: 'Enter at least 2 characters.', phoneError: 'Enter a phone number with area code.', review: 'Please review the highlighted required fields.', sending: 'Sending…', sendError: 'Could not send — please try again', discard: 'Discard the information you entered?',
  },
  es: {
    close: 'Cerrar', title: 'Sesión de diagnóstico', accent: 'gratuita', name: 'Nombre completo', namePlaceholder: 'Su nombre', company: 'Empresa y cargo', companyPlaceholder: 'Nombre de la empresa', email: 'Correo electrónico', emailPlaceholder: 'usted@ejemplo.com', phone: 'Teléfono / WhatsApp', phonePlaceholder: '+00 000 000 0000', revenue: 'Facturación mensual promedio', revenuePrompt: 'Seleccione un rango', revenueOptions: ['Hasta R$ 50 mil', 'R$ 50 mil – R$ 150 mil', 'R$ 150 mil – R$ 500 mil', 'R$ 500 mil – R$ 2 millones', 'Más de R$ 2 millones'], source: '¿Cómo nos conoció?', sourcePrompt: 'Seleccione una opción', referral: 'Recomendación', other: 'Otro', submit: 'SOLICITAR SESIÓN DE DIAGNÓSTICO GRATUITA →', footer: 'Sin compromiso · Respuesta en hasta 24 horas', network: 'No pudimos completar el envío. Sus datos siguen completos.', whatsapp: 'Hablar por WhatsApp', successTitle: 'Solicitud recibida', success: 'Su navegador envió la información. Si no recibe respuesta en hasta 24 horas, contáctenos por WhatsApp.', required: 'Este campo es obligatorio.', minChars: 'Ingrese al menos 2 caracteres.', phoneError: 'Ingrese un teléfono con código de área.', review: 'Revise los campos obligatorios resaltados.', sending: 'Enviando…', sendError: 'No se pudo enviar — intente nuevamente', discard: '¿Descartar los datos ingresados?',
  },
}[locale];

/* ─── Cria o HTML do modal ─── */
function createModal() {
  const el = document.createElement('div');
  el.id = 'modal-diagnostico';
  el.className = 'modal-diag-overlay';
  el.setAttribute('role', 'dialog');
  el.setAttribute('aria-modal', 'true');
  el.setAttribute('aria-labelledby', 'modal-diag-title');
  el.setAttribute('hidden', '');
  el.innerHTML = `
    <div class="modal-diag-box" role="document">
      <button class="modal-diag-close" id="modal-diag-close" aria-label="${copy.close}">✕</button>
      <p class="modal-diag-brand">CATALISE.ME</p>
      <h2 id="modal-diag-title" class="modal-diag-title" tabindex="-1">
        ${copy.title} <span>${copy.accent}</span>
      </h2>
      <form id="modal-diag-form" class="modal-diag-form" novalidate aria-describedby="modal-diag-status">
        <p id="modal-diag-status" class="visually-hidden" aria-live="polite"></p>
        <div class="modal-diag-row">
          <div class="modal-diag-field">
            <label for="diag-name">${copy.name} <span aria-hidden="true">*</span></label>
            <input type="text" id="diag-name" name="name" placeholder="${copy.namePlaceholder}" required autocomplete="name" aria-describedby="diag-name-error">
            <span class="modal-diag-error" id="diag-name-error" aria-live="polite"></span>
          </div>
          <div class="modal-diag-field">
            <label for="diag-company">${copy.company} <span aria-hidden="true">*</span></label>
            <input type="text" id="diag-company" name="company" placeholder="${copy.companyPlaceholder}" required autocomplete="organization" aria-describedby="diag-company-error">
            <span class="modal-diag-error" id="diag-company-error" aria-live="polite"></span>
          </div>
        </div>
        <div class="modal-diag-field">
          <label for="diag-email">${copy.email} <span aria-hidden="true">*</span></label>
          <input type="email" id="diag-email" name="email" placeholder="${copy.emailPlaceholder}" required autocomplete="email" aria-describedby="diag-email-error">
          <span class="modal-diag-error" id="diag-email-error" aria-live="polite"></span>
        </div>
        <div class="modal-diag-field">
          <label for="diag-phone">${copy.phone} <span aria-hidden="true">*</span></label>
          <input type="tel" id="diag-phone" name="phone" placeholder="${copy.phonePlaceholder}" required autocomplete="tel" aria-describedby="diag-phone-error">
          <span class="modal-diag-error" id="diag-phone-error" aria-live="polite"></span>
        </div>
        <div class="modal-diag-field">
          <label for="diag-revenue">${copy.revenue} <span aria-hidden="true">*</span></label>
          <select id="diag-revenue" name="revenue" required aria-describedby="diag-revenue-error">
            <option value="" disabled selected>${copy.revenuePrompt}</option>
            <option value="ate-50k">${copy.revenueOptions[0]}</option>
            <option value="50k-150k">${copy.revenueOptions[1]}</option>
            <option value="150k-500k">${copy.revenueOptions[2]}</option>
            <option value="500k-2m">${copy.revenueOptions[3]}</option>
            <option value="acima-2m">${copy.revenueOptions[4]}</option>
          </select>
          <span class="modal-diag-error" id="diag-revenue-error" aria-live="polite"></span>
        </div>
        <div class="modal-diag-field">
          <label for="diag-source">${copy.source} <span aria-hidden="true">*</span></label>
          <select id="diag-source" name="source" required aria-describedby="diag-source-error">
            <option value="" disabled selected>${copy.sourcePrompt}</option>
            <option value="instagram">Instagram</option>
            <option value="linkedin">LinkedIn</option>
            <option value="google">Google</option>
            <option value="indicacao">${copy.referral}</option>
            <option value="youtube">YouTube</option>
            <option value="outro">${copy.other}</option>
          </select>
          <span class="modal-diag-error" id="diag-source-error" aria-live="polite"></span>
        </div>
        <button type="submit" class="modal-diag-submit" id="modal-diag-submit">
          ${copy.submit}
        </button>
        <p class="modal-diag-footer">${copy.footer}</p>
        <div class="modal-diag-network-error" id="modal-diag-network-error" role="alert" hidden>
          <p>${copy.network}</p>
          <a href="https://wa.me/5575991879786" target="_blank" rel="noopener">${copy.whatsapp}</a>
        </div>
      </form>
      <div class="modal-diag-success" id="modal-diag-success" role="status" aria-live="polite" tabindex="-1" hidden>
        <div class="modal-diag-success-icon">✓</div>
        <h3 tabindex="-1">${copy.successTitle}</h3>
        <p>${copy.success}</p>
        <button class="modal-diag-submit" id="modal-diag-success-close" style="margin-top:24px">${copy.close}</button>
      </div>
    </div>
  `;
  return el;
}

/* ─── Estado do modal ─── */
let modal: HTMLElement | null = null;
let previousFocus: Element | null = null;

function openModal() {
  if (!modal) return;
  previousFocus = document.activeElement;
  const form = modal.querySelector<HTMLFormElement>('#modal-diag-form');
  const success = modal.querySelector<HTMLElement>('#modal-diag-success');
  const networkError = modal.querySelector<HTMLElement>('#modal-diag-network-error');
  const submit = form?.querySelector<HTMLButtonElement>('[type=submit]');
  if (success && !success.hidden && form) {
    form.reset();
    form.hidden = false;
    success.hidden = true;
  }
  if (networkError) networkError.hidden = true;
  if (submit) {
    submit.disabled = false;
    submit.textContent = copy.submit;
    submit.removeAttribute('style');
  }
  modal.removeAttribute('hidden');
  document.body.classList.add('modal-open');
  modal.offsetHeight; // força reflow
  modal.classList.add('is-open');
  setTimeout(() => {
    if (!modal?.classList.contains('is-open')) return;
    const first = modal!.querySelector<HTMLElement>('#modal-diag-title, input, select, button');
    if (first) first.focus();
  }, 80);
}

function closeModal() {
  if (!modal) return;
  const form = modal.querySelector<HTMLFormElement>('#modal-diag-form');
  if (form && !form.hidden && [...new FormData(form).values()].some((value) => String(value).trim()) &&
      !window.confirm(copy.discard)) return;
  modal.classList.remove('is-open');
  document.body.classList.remove('modal-open');
  const hideClosedModal = () => {
    if (!modal?.classList.contains('is-open')) modal?.setAttribute('hidden', '');
  };
  modal.addEventListener('transitionend', hideClosedModal, { once: true });
  setTimeout(hideClosedModal, 450);
  if (previousFocus instanceof HTMLElement) previousFocus.focus();
}

/* ─── Máscara WhatsApp ─── */
function maskPhone(input: HTMLInputElement) {
  input.addEventListener('input', () => {
    let v = input.value.replace(/\D/g, '');
    if (v.length > 11) v = v.slice(0, 11);
    if (v.length > 6)      v = `(${v.slice(0,2)}) ${v.slice(2,7)}-${v.slice(7)}`;
    else if (v.length > 2) v = `(${v.slice(0,2)}) ${v.slice(2)}`;
    else if (v.length > 0) v = `(${v}`;
    input.value = v;
  });
}

/* ─── Submissão ─── */
async function handleSubmit(e: Event) {
  e.preventDefault();
  const form = e.target as HTMLFormElement;
  const btn = form.querySelector<HTMLButtonElement>('[type=submit]');
  const requiredFields = [...form.querySelectorAll<HTMLInputElement | HTMLSelectElement>('[required]')];
  const validateField = (field: HTMLInputElement | HTMLSelectElement) => {
    let message = '';
    if (!field.validity.valid) message = copy.required;
    if ((field.id === 'diag-name' || field.id === 'diag-company') && field.value.trim().length < 2) message = copy.minChars;
    if (field.id === 'diag-phone' && field.value.replace(/\D/g, '').length < 10) message = copy.phoneError;
    field.setAttribute('aria-invalid', String(Boolean(message)));
    const error = form.querySelector<HTMLElement>(`#${field.id}-error`);
    if (error) error.textContent = message;
    return !message;
  };
  requiredFields.forEach(validateField);
  const firstInvalid = requiredFields.find((field) => field.getAttribute('aria-invalid') === 'true');
  if (firstInvalid) {
    (form.querySelector('#modal-diag-status') as HTMLElement).textContent = copy.review;
    firstInvalid.focus();
    return;
  }
  if (!btn) return;

  btn.textContent = copy.sending;
  btn.disabled = true;
  const networkError = form.querySelector<HTMLElement>('#modal-diag-network-error');
  if (networkError) networkError.hidden = true;

  const data = new FormData(form);
  const body = Object.fromEntries(data.entries());
  const controller = new AbortController();
  const timeoutId = window.setTimeout(() => controller.abort(), 15000);

  try {
    await fetch(
      'https://triviumlabs.sg.larksuite.com/base/automation/webhook/event/THgIaGzH4wWd2lhVeDtlC4D5gAh',
      {
        method: 'POST',
        mode: 'no-cors',
        headers: { 'Content-Type': 'text/plain' },
        body: JSON.stringify(body),
        signal: controller.signal,
      }
    );
    form.hidden = true;
    const success = document.getElementById('modal-diag-success')!;
    success.hidden = false;
    success.focus();
  } catch (err) {
    console.error('[Modal Diagnóstico] Erro ao enviar:', err);
    btn.textContent = copy.sendError;
    btn.disabled = false;
    btn.style.background = '#e53e3e';
    btn.style.color = '#fff';
    if (networkError) networkError.hidden = false;
  } finally {
    clearTimeout(timeoutId);
  }
}

/* ─── Trap de foco ─── */
function trapFocus(e: KeyboardEvent) {
  if (!modal || !modal.classList.contains('is-open')) return;
  const focusable = [...modal.querySelectorAll<HTMLElement>(
    'button, input, select, textarea, [tabindex]:not([tabindex="-1"])'
  )].filter(el => !el.hasAttribute('disabled') && !el.closest('[hidden]') && el.getClientRects().length > 0);
  const first = focusable[0];
  const last  = focusable[focusable.length - 1];
  if (e.key === 'Tab') {
    if (e.shiftKey && document.activeElement === first) {
      e.preventDefault(); last.focus();
    } else if (!e.shiftKey && document.activeElement === last) {
      e.preventDefault(); first.focus();
    }
  }
  if (e.key === 'Escape') closeModal();
}

/* ─── Helper: intercepta clique e abre modal ─── */
function intercept(el: Element) {
  el.addEventListener('click', (e) => {
    if (e instanceof MouseEvent && (e.button !== 0 || e.metaKey || e.ctrlKey || e.shiftKey || e.altKey)) return;
    e.preventDefault();
    openModal();
  });
}

/* ─── Inicialização ─── */
function init() {
  modal = createModal();
  document.body.appendChild(modal);

  modal.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });
  modal.querySelector('#modal-diag-close')!.addEventListener('click', closeModal);
  modal.querySelector('#modal-diag-success-close')!.addEventListener('click', closeModal);
  modal.querySelector('#modal-diag-form')!.addEventListener('submit', handleSubmit);
  maskPhone(modal.querySelector<HTMLInputElement>('#diag-phone')!);
  document.addEventListener('keydown', trapFocus);

  // 1) Intercepta por ID/classe explícita
  TRIGGER_SELECTORS.forEach(sel => {
    document.querySelectorAll(sel).forEach(intercept);
  });

  // Links comuns continuam apontando para /contato como fallback progressivo.
}

if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', init);
} else {
  init();
}
</script>
