---
// Modal Diagnóstico Gratuito — injected on pages that have CTA buttons
---

<script>
/* =========================================
   CATALISE.ME — MODAL DIAGNÓSTICO GRATUITO
   ES Module — compatível com Astro build
   ========================================= */

/* ─── Seletores de botões que devem abrir o modal ─── */
const TRIGGER_SELECTORS = [
  '#hero-cta-primary',
  '#final-cta-primary',
  '#opera-hero-cta',
  '#opera-final-cta',
  '#comecar-cta',
  '#pricing-cta-primary',
  '#sobre-cta-primary',
  '#sticky-cta-btn',
  '.nav-cta-modal',
  '.mobile-cta-modal',
];

/* ─── Cria o HTML do modal ─── */
function createModal() {
  const el = document.createElement('div');
  el.id = 'modal-diagnostico';
  el.className = 'modal-diag-overlay';
  el.setAttribute('role', 'dialog');
  el.setAttribute('aria-modal', 'true');
  el.setAttribute('aria-labelledby', 'modal-diag-title');
  el.setAttribute('hidden', '');
  el.innerHTML = `
    <div class="modal-diag-box" role="document">
      <button class="modal-diag-close" id="modal-diag-close" aria-label="Fechar">✕</button>
      <p class="modal-diag-brand">CATALISE.ME</p>
      <h2 id="modal-diag-title" class="modal-diag-title" tabindex="-1">
        Diagnóstico <span>Gratuito</span>
      </h2>
      <form id="modal-diag-form" class="modal-diag-form" novalidate aria-describedby="modal-diag-status">
        <p id="modal-diag-status" class="visually-hidden" aria-live="polite"></p>
        <div class="modal-diag-row">
          <div class="modal-diag-field">
            <label for="diag-name">Nome completo <span aria-hidden="true">*</span></label>
            <input type="text" id="diag-name" name="name" placeholder="Seu nome" required autocomplete="name" aria-describedby="diag-name-error">
            <span class="modal-diag-error" id="diag-name-error" aria-live="polite"></span>
          </div>
          <div class="modal-diag-field">
            <label for="diag-company">Empresa e cargo <span aria-hidden="true">*</span></label>
            <input type="text" id="diag-company" name="company" placeholder="Nome da empresa" required autocomplete="organization" aria-describedby="diag-company-error">
            <span class="modal-diag-error" id="diag-company-error" aria-live="polite"></span>
          </div>
        </div>
        <div class="modal-diag-field">
          <label for="diag-email">E-mail <span aria-hidden="true">*</span></label>
          <input type="email" id="diag-email" name="email" placeholder="seu@email.com" required autocomplete="email" aria-describedby="diag-email-error">
          <span class="modal-diag-error" id="diag-email-error" aria-live="polite"></span>
        </div>
        <div class="modal-diag-field">
          <label for="diag-phone">Telefone / WhatsApp <span aria-hidden="true">*</span></label>
          <input type="tel" id="diag-phone" name="phone" placeholder="(00) 90000-0000" required autocomplete="tel" aria-describedby="diag-phone-error">
          <span class="modal-diag-error" id="diag-phone-error" aria-live="polite"></span>
        </div>
        <div class="modal-diag-field">
          <label for="diag-revenue">Faturamento médio mensal <span aria-hidden="true">*</span></label>
          <select id="diag-revenue" name="revenue" required aria-describedby="diag-revenue-error">
            <option value="" disabled selected>Selecione uma faixa</option>
            <option value="ate-50k">Até R$ 50 mil</option>
            <option value="50k-150k">R$ 50 mil – R$ 150 mil</option>
            <option value="150k-500k">R$ 150 mil – R$ 500 mil</option>
            <option value="500k-2m">R$ 500 mil – R$ 2 milhões</option>
            <option value="acima-2m">Acima de R$ 2 milhões</option>
          </select>
          <span class="modal-diag-error" id="diag-revenue-error" aria-live="polite"></span>
        </div>
        <div class="modal-diag-field">
          <label for="diag-source">Como ficou sabendo sobre nós? <span aria-hidden="true">*</span></label>
          <select id="diag-source" name="source" required aria-describedby="diag-source-error">
            <option value="" disabled selected>Selecione uma opção</option>
            <option value="instagram">Instagram</option>
            <option value="linkedin">LinkedIn</option>
            <option value="google">Google</option>
            <option value="indicacao">Indicação</option>
            <option value="youtube">YouTube</option>
            <option value="outro">Outro</option>
          </select>
          <span class="modal-diag-error" id="diag-source-error" aria-live="polite"></span>
        </div>
        <button type="submit" class="modal-diag-submit" id="modal-diag-submit">
          SOLICITAR DIAGNÓSTICO GRATUITO →
        </button>
        <p class="modal-diag-footer">Sem compromisso · Resposta em até 24h</p>
        <div class="modal-diag-network-error" id="modal-diag-network-error" role="alert" hidden>
          <p>Não foi possível concluir o envio agora. Seus dados continuam preenchidos.</p>
          <a href="https://wa.me/5575991879786" target="_blank" rel="noopener">Falar pelo WhatsApp</a>
        </div>
      </form>
      <div class="modal-diag-success" id="modal-diag-success" role="status" aria-live="polite" tabindex="-1" hidden>
        <div class="modal-diag-success-icon">✓</div>
        <h3 tabindex="-1">Solicitação encaminhada</h3>
        <p>Seu navegador encaminhou os dados. Se não receber nosso contato em até 24 horas, fale com a gente pelo WhatsApp.</p>
        <button class="modal-diag-submit" id="modal-diag-success-close" style="margin-top:24px">Fechar</button>
      </div>
    </div>
  `;
  return el;
}

/* ─── Estado do modal ─── */
let modal: HTMLElement | null = null;
let previousFocus: Element | null = null;

function openModal() {
  if (!modal) return;
  previousFocus = document.activeElement;
  const form = modal.querySelector<HTMLFormElement>('#modal-diag-form');
  const success = modal.querySelector<HTMLElement>('#modal-diag-success');
  const networkError = modal.querySelector<HTMLElement>('#modal-diag-network-error');
  const submit = form?.querySelector<HTMLButtonElement>('[type=submit]');
  if (success && !success.hidden && form) {
    form.reset();
    form.hidden = false;
    success.hidden = true;
  }
  if (networkError) networkError.hidden = true;
  if (submit) {
    submit.disabled = false;
    submit.textContent = 'SOLICITAR DIAGNÓSTICO GRATUITO →';
    submit.removeAttribute('style');
  }
  modal.removeAttribute('hidden');
  document.body.classList.add('modal-open');
  modal.offsetHeight; // força reflow
  modal.classList.add('is-open');
  setTimeout(() => {
    if (!modal?.classList.contains('is-open')) return;
    const first = modal!.querySelector<HTMLElement>('#modal-diag-title, input, select, button');
    if (first) first.focus();
  }, 80);
}

function closeModal() {
  if (!modal) return;
  const form = modal.querySelector<HTMLFormElement>('#modal-diag-form');
  if (form && !form.hidden && [...new FormData(form).values()].some((value) => String(value).trim()) &&
      !window.confirm('Descartar os dados preenchidos?')) return;
  modal.classList.remove('is-open');
  document.body.classList.remove('modal-open');
  const hideClosedModal = () => {
    if (!modal?.classList.contains('is-open')) modal?.setAttribute('hidden', '');
  };
  modal.addEventListener('transitionend', hideClosedModal, { once: true });
  setTimeout(hideClosedModal, 450);
  if (previousFocus instanceof HTMLElement) previousFocus.focus();
}

/* ─── Máscara WhatsApp ─── */
function maskPhone(input: HTMLInputElement) {
  input.addEventListener('input', () => {
    let v = input.value.replace(/\D/g, '');
    if (v.length > 11) v = v.slice(0, 11);
    if (v.length > 6)      v = `(${v.slice(0,2)}) ${v.slice(2,7)}-${v.slice(7)}`;
    else if (v.length > 2) v = `(${v.slice(0,2)}) ${v.slice(2)}`;
    else if (v.length > 0) v = `(${v}`;
    input.value = v;
  });
}

/* ─── Submissão ─── */
async function handleSubmit(e: Event) {
  e.preventDefault();
  const form = e.target as HTMLFormElement;
  const btn = form.querySelector<HTMLButtonElement>('[type=submit]');
  const requiredFields = [...form.querySelectorAll<HTMLInputElement | HTMLSelectElement>('[required]')];
  const validateField = (field: HTMLInputElement | HTMLSelectElement) => {
    let message = '';
    if (!field.validity.valid) message = 'Campo obrigatório.';
    if ((field.id === 'diag-name' || field.id === 'diag-company') && field.value.trim().length < 2) message = 'Informe pelo menos 2 caracteres.';
    if (field.id === 'diag-phone' && field.value.replace(/\D/g, '').length < 10) message = 'Informe um telefone com DDD.';
    field.setAttribute('aria-invalid', String(Boolean(message)));
    const error = form.querySelector<HTMLElement>(`#${field.id}-error`);
    if (error) error.textContent = message;
    return !message;
  };
  requiredFields.forEach(validateField);
  const firstInvalid = requiredFields.find((field) => field.getAttribute('aria-invalid') === 'true');
  if (firstInvalid) {
    (form.querySelector('#modal-diag-status') as HTMLElement).textContent = 'Revise os campos obrigatórios destacados.';
    firstInvalid.focus();
    return;
  }
  if (!btn) return;

  btn.textContent = 'Enviando…';
  btn.disabled = true;
  const networkError = form.querySelector<HTMLElement>('#modal-diag-network-error');
  if (networkError) networkError.hidden = true;

  const data = new FormData(form);
  const body = Object.fromEntries(data.entries());
  const controller = new AbortController();
  const timeoutId = window.setTimeout(() => controller.abort(), 15000);

  try {
    await fetch(
      'https://triviumlabs.sg.larksuite.com/base/automation/webhook/event/THgIaGzH4wWd2lhVeDtlC4D5gAh',
      {
        method: 'POST',
        mode: 'no-cors',
        headers: { 'Content-Type': 'text/plain' },
        body: JSON.stringify(body),
        signal: controller.signal,
      }
    );
    form.hidden = true;
    const success = document.getElementById('modal-diag-success')!;
    success.hidden = false;
    success.focus();
  } catch (err) {
    console.error('[Modal Diagnóstico] Erro ao enviar:', err);
    btn.textContent = 'Erro ao enviar — tente novamente';
    btn.disabled = false;
    btn.style.background = '#e53e3e';
    btn.style.color = '#fff';
    if (networkError) networkError.hidden = false;
  } finally {
    clearTimeout(timeoutId);
  }
}

/* ─── Trap de foco ─── */
function trapFocus(e: KeyboardEvent) {
  if (!modal || !modal.classList.contains('is-open')) return;
  const focusable = [...modal.querySelectorAll<HTMLElement>(
    'button, input, select, textarea, [tabindex]:not([tabindex="-1"])'
  )].filter(el => !el.hasAttribute('disabled') && !el.closest('[hidden]') && el.getClientRects().length > 0);
  const first = focusable[0];
  const last  = focusable[focusable.length - 1];
  if (e.key === 'Tab') {
    if (e.shiftKey && document.activeElement === first) {
      e.preventDefault(); last.focus();
    } else if (!e.shiftKey && document.activeElement === last) {
      e.preventDefault(); first.focus();
    }
  }
  if (e.key === 'Escape') closeModal();
}

/* ─── Helper: intercepta clique e abre modal ─── */
function intercept(el: Element) {
  el.addEventListener('click', (e) => {
    if (e instanceof MouseEvent && (e.button !== 0 || e.metaKey || e.ctrlKey || e.shiftKey || e.altKey)) return;
    e.preventDefault();
    openModal();
  });
}

/* ─── Inicialização ─── */
function init() {
  modal = createModal();
  document.body.appendChild(modal);

  modal.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });
  modal.querySelector('#modal-diag-close')!.addEventListener('click', closeModal);
  modal.querySelector('#modal-diag-success-close')!.addEventListener('click', closeModal);
  modal.querySelector('#modal-diag-form')!.addEventListener('submit', handleSubmit);
  maskPhone(modal.querySelector<HTMLInputElement>('#diag-phone')!);
  document.addEventListener('keydown', trapFocus);

  // 1) Intercepta por ID/classe explícita
  TRIGGER_SELECTORS.forEach(sel => {
    document.querySelectorAll(sel).forEach(intercept);
  });

  // Links comuns continuam apontando para /contato como fallback progressivo.
}

if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', init);
} else {
  init();
}
</script>
