  '#final-cta-primary',
  '#opera-hero-cta',
  '#opera-final-cta',
  '#comecar-cta',
  '#pricing-cta-primary',
  '#sobre-cta-primary',
  '#sticky-cta-btn',
  '.nav-cta-modal',
  '.mobile-cta-modal',
];

const locale = document.documentElement.lang.startsWith('en') ? 'en' : document.documentElement.lang.startsWith('es') ? 'es' : 'pt';
const copy = {
  pt: {
